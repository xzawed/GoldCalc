# 금시세 API (GoldAPI.io) — Railway 서버사이드 전용 (VITE_ 접두사 없음)
# https://www.goldapi.io/
GOLD_API_KEY=
GOLD_API_URL=https://www.goldapi.io/api

# 환율 API (ExchangeRate-API v6) — Railway 서버사이드 전용
# https://www.exchangerate-api.com/
EXCHANGE_RATE_API_KEY=
EXCHANGE_RATE_API_URL=https://v6.exchangerate-api.com/v6

# 국내 금시세 API (data.go.kr) — Railway 서버사이드 전용
# https://www.data.go.kr/
DATA_GO_KR_API_KEY=

# 보조 지표 (선택) — Railway 서버사이드 전용
FRED_API_KEY=
ALPHA_VANTAGE_KEY=

# X(Twitter) 뉴스 (선택) — Railway 서버사이드 전용
# 미설정 시 /api/x-news는 503 반환, 뉴스 섹션 에러 표시
X_BEARER_TOKEN=
# X_LIST_ID 미설정 시 기본 리스트(2043297405916090454) 사용
X_LIST_ID=

# Supabase 페일오버 — Railway 장애 시 자동 전환 (선택, 미설정 시 페일오버 비활성)
# 프로젝트 URL: Supabase 대시보드 Settings > API > Project URL
VITE_SUPABASE_URL=
